create schema productschema



-- Schema yarat (əgər yoxdursa)
CREATE SCHEMA IF NOT EXISTS productschema;

-- ENUM type-larını yarat (PostgreSQL native enum)
CREATE TYPE productschema.product_status_enum AS ENUM ('ACTIVE', 'SOLD', 'DELETED', 'DEACTIVATED', 'EXPIRED');

CREATE TYPE productschema.product_category_enum AS ENUM (
    'ELECTRONICS', 'WEAR', 'HOME_AND_GARDEN', 'CHILDREN', 'SPORT',
    'CAR', 'BOOK', 'BEAUTY', 'TOY', 'FOOD', 'ANIMALS', 'ART',
    'BUSINESS', 'SERVICES', 'OTHERS'
    );

CREATE TYPE productschema.city_enum AS ENUM (
    'BAKI', 'GENCE', 'SUMQAYIT', 'MINGECEVIR', 'SEKI', 'YEVLAX', 'LENKERAN',
    'SIRVAN', 'NAFTALAN', 'SUSA', 'XANKENDI', 'ABSHERON', 'AGCABEDI',
    'AGDAM', 'AGDAS', 'AGSTAF', 'AGSU', 'ASTARA', 'BALAKEN', 'BERDE',
    'BEYLEQAN', 'BILESUVAR', 'CABRAYIL', 'CELILABAD', 'DASKESAN', 'FUZULI',
    'GEDEBEY', 'GORANBOY', 'GOYCHAY', 'GOYGOL', 'HACIQABUL', 'IMISHLI',
    'ISMAILLI', 'KALBAJAR', 'KURDAMIR', 'LACHIN', 'LERIK', 'MASALLI',
    'NEFTCHALA', 'OGUZ', 'GABALA', 'GAKH', 'GAZAKH', 'GOBUSTAN', 'GUBA',
    'GUBADLI', 'GUSAR', 'SAATLI', 'SABIRABAD', 'SALYAN', 'SHAMAKHI',
    'SHAMKIR', 'SIYAZAN', 'TARTAR', 'TOVUZ', 'UCAR', 'KHACHMAZ', 'KHIZI',
    'KHOJALI', 'KHOJAVEND', 'YARDIMLI', 'ZANGILAN', 'ZAGATALA', 'ZARDAB',
    'NAKHCHIVAN_CITY', 'BABEK', 'CULFA', 'KANGARLI', 'ORDUBAD', 'SADEREK',
    'SHAHBUZ', 'SHARUR'
    );


CREATE TABLE productschema.products (
                                        id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
                                        user_id UUID NOT NULL,
                                        title VARCHAR(255) NOT NULL,
                                        description TEXT,
                                        price NUMERIC(12, 2) NOT NULL CHECK (price >= 0),
                                        is_new BOOLEAN DEFAULT FALSE,
                                        category productschema.product_category_enum NOT NULL,
                                        is_delivery BOOLEAN DEFAULT FALSE,
                                        city productschema.city_enum NOT NULL,
                                        status productschema.product_status_enum NOT NULL DEFAULT 'ACTIVE',
                                        viewers BIGINT DEFAULT 0 CHECK (viewers >= 0),
                                        created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                                        updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- updated_at üçün trigger (automatik yenilənmə)
CREATE OR REPLACE FUNCTION productschema.update_updated_at_column()
    RETURNS TRIGGER AS $$
BEGIN
    NEW.updated_at = CURRENT_TIMESTAMP;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_update_products_updated_at
    BEFORE UPDATE ON productschema.products
    FOR EACH ROW
EXECUTE FUNCTION productschema.update_updated_at_column();


CREATE TABLE productschema.product_images (
                                              id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
                                              image_url VARCHAR(500) NOT NULL,
                                              sort_order INTEGER DEFAULT 0,
                                              product_id UUID NOT NULL REFERENCES productschema.products(id) ON DELETE CASCADE,
                                              created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);


-- Tez-tez filterlənən sütunlar
CREATE INDEX idx_products_user_id ON productschema.products(user_id);
CREATE INDEX idx_products_status ON productschema.products(status);
CREATE INDEX idx_products_city ON productschema.products(city);
CREATE INDEX idx_products_category ON productschema.products(category);
CREATE INDEX idx_products_price ON productschema.products(price);
CREATE INDEX idx_products_created_at ON productschema.products(created_at DESC);
CREATE INDEX idx_products_is_new ON productschema.products(is_new) WHERE is_new = TRUE;
CREATE INDEX idx_products_is_delivery ON productschema.products(is_delivery) WHERE is_delivery = TRUE;

-- Composite indexes (çoxlu filter üçün optimallaşdırma)
CREATE INDEX idx_products_status_city_category
    ON productschema.products(status, city, category);

CREATE INDEX idx_products_user_created
    ON productschema.products(user_id, created_at DESC);

CREATE INDEX idx_products_category_city_price
    ON productschema.products(category, city, price);

-- Title üçün search (case-insensitive)
CREATE INDEX idx_products_title_lower ON productschema.products(LOWER(title));

-- Full-text search üçün (istəyə bağlı, böyük mətn axtarışı üçün)
CREATE INDEX idx_products_title_desc_fts
    ON productschema.products
        USING GIN (to_tsvector('simple', coalesce(title, '') || ' ' || coalesce(description, '')));



CREATE INDEX idx_product_images_product_id ON productschema.product_images(product_id);
CREATE INDEX idx_product_images_sort_order ON productschema.product_images(product_id, sort_order);

